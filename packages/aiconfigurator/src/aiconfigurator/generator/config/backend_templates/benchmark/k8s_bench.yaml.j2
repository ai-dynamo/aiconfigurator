{%- set pvc_name = (K8sConfig.k8s_pvc_name or K8sConfig.k8s_model_cache or '') | trim -%}
{%- set use_pvc = (pvc_name != '') -%}
{%- set pvc_mount_path = K8sConfig.k8s_pvc_mount_path | default('/workspace/model_cache') -%}
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ BenchConfig.name }}
  namespace: {{ K8sConfig.k8s_namespace | default("default") }}
spec:
  backoffLimit: 0
  template:
    metadata:
      name: {{ BenchConfig.name }}
    spec:
      restartPolicy: Never
      {% if use_pvc %}
      volumes:
        - name: pvc
          persistentVolumeClaim:
            claimName: {{ pvc_name }}
      {% endif %}
      containers:
        - name: aiperf
          image: {{ BenchConfig.image }}
          env:
            - name: AIPERF_SERVICE_PROFILE_START_TIMEOUT
              value: "{{ BenchConfig.profile_start_timeout }}"
            {% if use_pvc %}
            - name: BENCH_ARTIFACT_DIR
              value: "{{ pvc_mount_path }}/bench_artifacts"
            {% endif %}
          {% if use_pvc %}
          volumeMounts:
            - name: pvc
              mountPath: {{ pvc_mount_path }}
          {% endif %}
          command: ["/bin/bash", "-c"]
          args:
            - |
              pip install aiperf
              {% set base_concurrency = [1, 2, 8, 16, 32, 64, 128] %}
              {% if BenchConfig.estimated_concurrency and BenchConfig.estimated_concurrency > 0 %}
              {% set eff = BenchConfig.estimated_concurrency | int %}
              {% set eff_low = (BenchConfig.estimated_concurrency * 0.95) | int %}
              {% set eff_high = (BenchConfig.estimated_concurrency * 1.05) | int %}
              {% set combined = base_concurrency + [eff_low, eff, eff_high] %}
              {% set ns = namespace(seen=[]) %}
              {% for c in combined %}
              {% if c >= 1 and c not in ns.seen %}
              {% set ns.seen = ns.seen + [c] %}
              {% endif %}
              {% endfor %}
              concurrency_array=({{ ns.seen | sort | join(' ') }})
              {% else %}
              concurrency_array=({{ base_concurrency | join(' ') }})
              {% endif %}
              ARTIFACT_DIR="${BENCH_ARTIFACT_DIR:-/tmp/bench_artifacts}"
              BENCH_PREFIX="${AICONFIGURATOR_BENCH_PREFIX:-{{ BenchConfig.prefix | default(0) }}}"
              BENCH_PREFIX_PROMPTS="${AICONFIGURATOR_BENCH_PREFIX_PROMPTS:-{{ BenchConfig.prefix_prompt_pool_size | default(1) }}}"
              {% if (BenchConfig.image_batch_size | default(0)) | int > 0 %}
              BENCH_IMAGE_BATCH_SIZE="${AICONFIGURATOR_BENCH_IMAGE_BATCH_SIZE:-{{ BenchConfig.image_batch_size | default(0) }}}"
              BENCH_IMAGE_WIDTH_MEAN="${AICONFIGURATOR_BENCH_IMAGE_WIDTH_MEAN:-{{ BenchConfig.image_width_mean | default('') }}}"
              BENCH_IMAGE_WIDTH_STDDEV="${AICONFIGURATOR_BENCH_IMAGE_WIDTH_STDDEV:-{{ BenchConfig.image_width_stddev | default('') }}}"
              BENCH_IMAGE_HEIGHT_MEAN="${AICONFIGURATOR_BENCH_IMAGE_HEIGHT_MEAN:-{{ BenchConfig.image_height_mean | default('') }}}"
              BENCH_IMAGE_HEIGHT_STDDEV="${AICONFIGURATOR_BENCH_IMAGE_HEIGHT_STDDEV:-{{ BenchConfig.image_height_stddev | default('') }}}"
              BENCH_IMAGE_FORMAT="${AICONFIGURATOR_BENCH_IMAGE_FORMAT:-{{ BenchConfig.image_format | default('') }}}"
              BENCH_IMAGE_SOURCE="${AICONFIGURATOR_BENCH_IMAGE_SOURCE:-{{ BenchConfig.image_source | default('') }}}"
              {% endif %}
              {% if BenchConfig.input_file | default('') %}
              BENCH_INPUT_FILE="${AICONFIGURATOR_BENCH_INPUT_FILE:-{{ BenchConfig.input_file | default('') }}}"
              BENCH_CUSTOM_DATASET_TYPE="${AICONFIGURATOR_BENCH_CUSTOM_DATASET_TYPE:-{{ BenchConfig.custom_dataset_type | default('') }}}"
              {% endif %}
              prefix_args=()
              if [[ "${BENCH_PREFIX}" =~ ^[0-9]+$ && "${BENCH_PREFIX}" -gt 0 \
                  && "${BENCH_PREFIX_PROMPTS}" =~ ^[0-9]+$ && "${BENCH_PREFIX_PROMPTS}" -gt 0 ]]; then
                prefix_args+=(--prefix-prompt-length "${BENCH_PREFIX}" --num-prefix-prompts "${BENCH_PREFIX_PROMPTS}")
              fi
              {% if (BenchConfig.image_batch_size | default(0)) | int > 0 %}
              image_args=()
              if [[ "${BENCH_IMAGE_BATCH_SIZE}" =~ ^[0-9]+$ && "${BENCH_IMAGE_BATCH_SIZE}" -gt 0 ]]; then
                image_args+=(--image-batch-size "${BENCH_IMAGE_BATCH_SIZE}")
                [[ -n "${BENCH_IMAGE_WIDTH_MEAN}" ]] && image_args+=(--image-width-mean "${BENCH_IMAGE_WIDTH_MEAN}")
                [[ -n "${BENCH_IMAGE_WIDTH_STDDEV}" ]] && image_args+=(--image-width-stddev "${BENCH_IMAGE_WIDTH_STDDEV}")
                [[ -n "${BENCH_IMAGE_HEIGHT_MEAN}" ]] && image_args+=(--image-height-mean "${BENCH_IMAGE_HEIGHT_MEAN}")
                [[ -n "${BENCH_IMAGE_HEIGHT_STDDEV}" ]] && image_args+=(--image-height-stddev "${BENCH_IMAGE_HEIGHT_STDDEV}")
                [[ -n "${BENCH_IMAGE_FORMAT}" ]] && image_args+=(--image-format "${BENCH_IMAGE_FORMAT}")
                [[ -n "${BENCH_IMAGE_SOURCE}" ]] && image_args+=(--image-source "${BENCH_IMAGE_SOURCE}")
              fi
              {% endif %}
              {% if BenchConfig.input_file | default('') %}
              input_file_args=()
              if [[ -n "${BENCH_INPUT_FILE}" && -f "${BENCH_INPUT_FILE}" ]]; then
                input_file_args+=(--input-file "${BENCH_INPUT_FILE}")
                [[ -n "${BENCH_CUSTOM_DATASET_TYPE}" ]] && input_file_args+=(--custom-dataset-type "${BENCH_CUSTOM_DATASET_TYPE}")
              fi
              {% endif %}
              for concurrency in "${concurrency_array[@]}"; do
                echo "Run concurrency: $concurrency"
                aiperf profile \
                  --artifact-dir "${ARTIFACT_DIR}/concurrency_${concurrency}" \
                  -m {{ BenchConfig.model }} \
                  --endpoint-type {{ BenchConfig.endpoint_type }} \
                  -u {{ BenchConfig.endpoint_url }} \
                  --tokenizer {{ BenchConfig.tokenizer }} \
                  --isl {{ BenchConfig.isl }} --isl-stddev {{ BenchConfig.isl_stddev }} \
                  --osl {{ BenchConfig.osl }} --osl-stddev {{ BenchConfig.osl_stddev }} \
                  "${prefix_args[@]}" \
                  {% if (BenchConfig.image_batch_size | default(0)) | int > 0 %}
                  "${image_args[@]}" \
                  {% endif %}
                  {% if BenchConfig.input_file | default('') %}
                  "${input_file_args[@]}" \
                  {% endif %}
                  --extra-inputs ignore_eos:true \
                  --extra-inputs "{\"nvext\":{\"ignore_eos\":true}}" \
                  --concurrency ${concurrency} \
                  --num-requests $(($concurrency*50)) \
                  --warmup-request-count $(($concurrency*2)) \
                  --random-seed 100 \
                  --ui {{ BenchConfig.ui }} \
                  --streaming
              done
