{#
  vLLM backend Kubernetes DynamoGraphDeployment template
  Uses shared macros for worker specs.
#}
{% from 'base_k8s.j2' import deployment_header, frontend_spec %}
{% import 'vllm.j2' as vllm %}

{{ deployment_header(DynConfig) }}
{{ frontend_spec(ServiceConfig, DynConfig) }}

{% set mode = DynConfig.mode | default('disagg') %}

{% if mode == 'agg' %}
{# ============ AGGREGATE MODE ============ #}
{{ vllm.k8s_worker(None, agg_gpu, agg_workers, agg_cli_args_list | default([]), ServiceConfig) }}

{% else %}
{# ============ DISAGGREGATE MODE ============ #}
{{ vllm.k8s_worker('prefill', prefill_gpu, prefill_workers, prefill_cli_args_list | default([]), ServiceConfig) }}
{{ vllm.k8s_worker('decode', decode_gpu, decode_workers, decode_cli_args_list | default([]), ServiceConfig) }}
{% endif %}
