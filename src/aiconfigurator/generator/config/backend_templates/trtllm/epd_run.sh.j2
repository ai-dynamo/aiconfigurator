#!/bin/bash
# Multimodal EPD (encode/prefill/decode) single-node colocated launcher.
#
# The encode worker is colocated on GPU 0 with the prefill (3-stage) or the
# aggregated PD worker (2-stage). This is required: dynamo's trtllm image-URL
# E-PD flow transfers vision embeddings via CUDA IPC, which needs the encode and
# downstream worker to share GPU memory access. k8s per-pod GPU isolation breaks
# that, so EPD runs as one pod (all workers as processes here) with overlapping
# GPUs. prefill->decode KV transfer still crosses GPUs via the normal transport.
set -e
trap 'echo "[epd] cleaning up..."; kill 0 2>/dev/null || true' EXIT INT TERM

export MODEL_PATH=${MODEL_PATH:-"{{ ServiceConfig.model_path }}"}
export SERVED_MODEL_NAME=${SERVED_MODEL_NAME:-"{{ ServiceConfig.served_model_name }}"}
export HF_TOKEN=${HF_TOKEN:-"{{ ServiceConfig.hf_token }}"}
# All workers share the pod-local DYN_NAMESPACE; the encode endpoint is pinned so
# the prefill/PD worker addresses it deterministically across dynamo versions.
ENCODE_ENDPOINT="dyn://${DYN_NAMESPACE:-dynamo}.encode.generate"

# Wait for the pod-local etcd discovery backend before starting workers.
echo "[epd] waiting for etcd at ${ETCD_ENDPOINTS:-localhost:2379}..."
for i in $(seq 1 60); do
  curl -sf "http://${ETCD_ENDPOINTS:-localhost:2379}/health" >/dev/null 2>&1 && { echo "[epd] etcd up"; break; }
  sleep 2
done

{% if ServiceConfig.include_frontend %}
python3 -m dynamo.frontend --http-port "{{ ServiceConfig.port | default(8000) }}" 2>&1 | sed "s/^/[Frontend] /" &
{% endif %}

# Encode worker (vision encoder) on GPU 0 — colocated with prefill/PD for CUDA IPC.
CUDA_VISIBLE_DEVICES=0 python3 -m dynamo.trtllm \
  --model-path "$MODEL_PATH" \
  --served-model-name "$SERVED_MODEL_NAME" \
  --extra-engine-args "/cfg/encode_config.yaml" \
  --endpoint "$ENCODE_ENDPOINT" \
  --modality {{ encode_modality | default('multimodal') }} \
  --allowed-local-media-path "{{ encode_allowed_local_media_path | default('/tmp') }}" \
  --max-file-size-mb {{ encode_max_file_size_mb | default(50) }} \
  --disaggregation-mode encode 2>&1 | sed "s/^/[Encode] /" &

{% if DynConfig.mode | default('disagg') == "agg" %}
AGG_GPU={{ agg_gpu }}
AGG_WORKERS={{ agg_workers }}
for ((w=0; w<AGG_WORKERS; w++)); do
  BASE=$(( w * AGG_GPU ))
  GPU_LIST=$(seq -s, $BASE $((BASE+AGG_GPU-1)))
  ( CUDA_VISIBLE_DEVICES=$GPU_LIST python3 -m dynamo.trtllm \
    --model-path "$MODEL_PATH" \
    --served-model-name "$SERVED_MODEL_NAME" \
    --extra-engine-args "/cfg/agg_config.yaml" \
    --modality {{ encode_modality | default('multimodal') }} \
    --encode-endpoint "$ENCODE_ENDPOINT" 2>&1 | sed "s/^/[Worker $w] /" ) &
done
{% else %}
PREFILL_GPU={{ prefill_gpu }}
PREFILL_WORKERS={{ prefill_workers }}
DECODE_GPU={{ decode_gpu }}
DECODE_WORKERS={{ decode_workers }}
# Prefill workers start at GPU 0 (worker 0 overlaps the encode worker on GPU 0).
for ((w=0; w<PREFILL_WORKERS; w++)); do
  BASE=$(( w * PREFILL_GPU ))
  GPU_LIST=$(seq -s, $BASE $((BASE+PREFILL_GPU-1)))
  ( CUDA_VISIBLE_DEVICES=$GPU_LIST python3 -m dynamo.trtllm \
    --model-path "$MODEL_PATH" \
    --served-model-name "$SERVED_MODEL_NAME" \
    --extra-engine-args "/cfg/prefill_config.yaml" \
    --modality {{ encode_modality | default('multimodal') }} \
    --encode-endpoint "$ENCODE_ENDPOINT" \
    --disaggregation-mode prefill 2>&1 | sed "s/^/[Prefill $w] /" ) &
done
# Decode workers placed after all prefill GPUs (true cross-GPU P->D disagg).
DECODE_OFFSET=$(( PREFILL_WORKERS * PREFILL_GPU ))
for ((w=0; w<DECODE_WORKERS; w++)); do
  BASE=$(( DECODE_OFFSET + w * DECODE_GPU ))
  GPU_LIST=$(seq -s, $BASE $((BASE+DECODE_GPU-1)))
  ( CUDA_VISIBLE_DEVICES=$GPU_LIST python3 -m dynamo.trtllm \
    --model-path "$MODEL_PATH" \
    --served-model-name "$SERVED_MODEL_NAME" \
    --extra-engine-args "/cfg/decode_config.yaml" \
    --modality {{ encode_modality | default('multimodal') }} \
    --disaggregation-mode decode 2>&1 | sed "s/^/[Decode $w] /" ) &
done
{% endif %}
wait
