{#
  SGLang backend Kubernetes DynamoGraphDeployment template
  Uses shared macros for worker specs.
#}
{% from 'base_k8s.j2' import deployment_header, frontend_spec %}
{% import 'sglang.j2' as sglang %}

{{ deployment_header(DynConfig) }}
{{ frontend_spec(ServiceConfig, DynConfig) }}

{% set mode = DynConfig.mode | default('disagg') %}

{% if mode == 'agg' %}
{# ============ AGGREGATE MODE ============ #}
{{ sglang.k8s_worker(None, agg_gpu, agg_workers, agg_cli_args, ServiceConfig) }}

{% else %}
{# ============ DISAGGREGATE MODE ============ #}
{{ sglang.k8s_worker('prefill', prefill_gpu, prefill_workers, prefill_cli_args, ServiceConfig) }}
{{ sglang.k8s_worker('decode', decode_gpu, decode_workers, decode_cli_args, ServiceConfig) }}
{% endif %}
